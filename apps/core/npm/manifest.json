{
  "$schema": "../../../manifest-schema.json",
  "version": "1.1",

  "app": {
    "sname": "npm",
    "pname": "Nginx Proxy Manager",
    "descriptionShort": "Reverse Proxy with SSL",
    "icon": "sh-nginx-proxy-manager",
    "category": "core"
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "webui": true,
    "port": 81,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "hybrid_mode"],
    "apps": []
  },

  "traefik": {
    "supported": false
  },

  "dashboard": {
    "enabled": true,
    "location": "other",
    "showStats": true,
    "portVariable": "NPM_ADMIN_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "NPM_ADMIN_PORT",
        "description": "Admin web interface port",
        "type": "port",
        "default": 81,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "03_npm_status",
    "successMessage": "Nginx Proxy Manager Setup Completed",
    "telemetryAction": "npm"
  }
}
