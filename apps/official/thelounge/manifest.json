{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "thelounge",
    "pname": "The Lounge",
    "description": "The Lounge is a modern, responsive, cross-platform, self-hosted web IRC client. It provides an always-connected experience with push notifications and link previews.",
    "descriptionShort": "Self-hosted web IRC client",
    "icon": "sh-thelounge",
    "category": "official",
    "menuNumber": "06",
    "tags": ["chat", "irc", "communication"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 9001,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "THELOUNGE_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "THELOUNGE_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 9001,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_thelounge_status",
    "successMessage": "The Lounge Setup Completed",
    "telemetryAction": "thelounge"
  }
}
