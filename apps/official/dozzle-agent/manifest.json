{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "dozzle-agent",
    "pname": "Dozzle Agent",
    "description": "Dozzle Agent enables remote Docker log monitoring by connecting to a central Dozzle instance. Install this on remote servers to aggregate logs.",
    "descriptionShort": "Remote Docker log monitoring",
    "icon": "sh-dozzle",
    "category": "official",
    "menuNumber": "06",
    "tags": ["docker", "logs", "monitoring", "remote", "agent"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "monitoring", "all"],
    "networks": ["default", "socket_proxy"],
    "webui": false,
    "port": 7007,
    "protocol": "https"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": ["socket-proxy"]
  },

  "postInstall": {
    "messages": [
      {
        "type": "note",
        "text": "$APP_PNAME does not have a WebUI. Use https://$SERVER_LAN_IP:$DOZZLEAGENT_PORT to connect Dozzle to Dozzle Agent."
      }
    ]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": false
  },

  "env": {
    "variables": [
      {
        "name": "DOZZLEAGENT_PORT",
        "description": "Agent connection port",
        "type": "port",
        "default": 7007,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_dozzle-agent_status",
    "successMessage": "Dozzle Agent Setup Completed",
    "telemetryAction": "dozzle-agent"
  }
}
