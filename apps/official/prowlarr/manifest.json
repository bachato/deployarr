{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "prowlarr",
    "pname": "Prowlarr",
    "description": "Prowlarr is an indexer manager/proxy built on the popular *arr .net/reactjs base stack to integrate with your various PVR apps. Prowlarr supports management of both Torrent Trackers and Usenet Indexers.",
    "descriptionShort": "Indexer proxy manager",
    "icon": "sh-prowlarr",
    "category": "official",
    "menuNumber": "06",
    "tags": ["media", "indexer", "starr"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "starr", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 9696,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "downloads_folder", "appfolder_permission"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "PROWLARR_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "PROWLARR_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 9696,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_prowlarr_status",
    "successMessage": "Prowlarr Setup Completed",
    "telemetryAction": "prowlarr"
  }
}
