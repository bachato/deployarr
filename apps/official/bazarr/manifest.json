{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "bazarr",
    "pname": "Bazarr",
    "description": "Bazarr is a companion application to Sonarr and Radarr that manages and downloads subtitles based on your requirements.",
    "descriptionShort": "Subtitle downloader for Radarr/Sonarr",
    "icon": "sh-bazarr",
    "category": "official",
    "menuNumber": "06",
    "tags": ["media", "subtitles", "sonarr", "radarr", "starr"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["media", "starr", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 6767,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "media_folder", "appfolder_permission"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "BAZARR_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "BAZARR_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 6767,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_bazarr_status",
    "successMessage": "Bazarr Setup Completed",
    "telemetryAction": "bazarr"
  }
}
