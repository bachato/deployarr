{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "esphome",
    "pname": "ESPHome",
    "description": "ESPHome is a system to control ESP8266/ESP32 microcontrollers for smart home applications. It provides a simple configuration language and integrates with Home Assistant.",
    "descriptionShort": "Smart home with ESP microcontrollers",
    "icon": "sh-esphome",
    "category": "official",
    "menuNumber": "06",
    "tags": ["home-automation", "iot", "smart-home"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 6052,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "ESPHOME_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "ESPHOME_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 6052,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_esphome_status",
    "successMessage": "ESPHome Setup Completed",
    "telemetryAction": "esphome"
  }
}
