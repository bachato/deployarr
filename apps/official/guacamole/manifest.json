{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "guacamole",
    "pname": "Guacamole",
    "description": "Apache Guacamole is a clientless remote desktop gateway. It supports standard protocols like VNC, RDP, and SSH. This installation uses a dedicated MariaDB database and the Guacamole daemon (guacd) for better isolation.",
    "descriptionShort": "Remote SSH, VNC, Telnet, and RDP viewer",
    "icon": "sh-guacamole",
    "category": "official",
    "menuNumber": "06",
    "tags": ["remote-access", "vnc", "rdp", "ssh", "telnet", "web"]
  },

  "deployment": {
    "type": "multicontainer",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8081,
    "protocol": "http"
  },

  "dependencies": [
    {
      "sname": "guacamole-mariadb",
      "pname": "Guacamole MariaDB",
      "compose": "guacamole-mariadb.yml",
      "installOrder": 1,
      "waitForHealthy": true,
      "required": true,
      "description": "Dedicated MariaDB database for Guacamole"
    },
    {
      "sname": "guacd",
      "pname": "Guacamole Daemon",
      "compose": "guacd.yml",
      "installOrder": 2,
      "waitForHealthy": false,
      "required": true,
      "description": "Guacamole connection proxy daemon"
    }
  ],

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "database": {
    "type": "mariadb",
    "containerSname": "guacamole-mariadb",
    "name": "guacamole",
    "user": "guacamole_db_user",
    "passwordVariable": "GUACAMOLE_MARIADB_PASSWORD",
    "host": "guacamole-mariadb",
    "port": 3306
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "GUACAMOLE_PORT"
  },

  "hooks": {
    "postInstall": "hooks/post-install.sh"
  },

  "env": {
    "variables": [
      {
        "name": "GUACAMOLE_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8081,
        "prompt": true,
        "required": true,
        "validation": { "type": "port", "min": 1, "max": 65535 }
      },
      {
        "name": "GUACAMOLE_MARIADB_ROOT_PASSWORD",
        "description": "MariaDB root password (auto-generated)",
        "type": "password",
        "generate": "random",
        "length": 32,
        "prompt": false,
        "required": true
      },
      {
        "name": "GUACAMOLE_MARIADB_PASSWORD",
        "description": "MariaDB database password (auto-generated)",
        "type": "password",
        "generate": "random",
        "length": 32,
        "prompt": false,
        "required": true
      }
    ]
  },

  "postInstall": {
    "messages": [
      {
        "type": "info",
        "text": "Default login: \\Z5guacadmin\\Zn / \\Z5guacadmin\\Zn - Change this immediately after first login!"
      },
      {
        "type": "note",
        "text": "Guacamole uses dedicated containers: \\Z5guacamole-mariadb\\Zn and \\Z5guacd\\Zn."
      },
      {
        "type": "note",
        "text": "Database credentials are stored in \\Z4$DOCKER_FOLDER/.env\\Zn."
      }
    ]
  },

  "status": {
    "file": "06_guacamole_status",
    "successMessage": "Guacamole Setup Completed",
    "telemetryAction": "guacamole"
  }
}
