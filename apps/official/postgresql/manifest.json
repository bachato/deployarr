{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "postgresql",
    "pname": "PostgreSQL",
    "description": "PostgreSQL is a powerful, open source object-relational database system with over 35 years of active development. It has earned a strong reputation for reliability, feature robustness, and performance.",
    "descriptionShort": "Open-source relational database",
    "icon": "sh-postgresql",
    "category": "official",
    "menuNumber": "06",
    "tags": ["database", "postgresql", "sql", "relational"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["core", "all"],
    "networks": ["default"],
    "webui": false,
    "port": 5432,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "env": {
    "variables": [
      {
        "name": "POSTGRESQL_PORT",
        "description": "Database port",
        "type": "port",
        "default": 5432,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      },
      {
        "name": "POSTGRES_DB",
        "description": "Default PostgreSQL Database (e.g. postgres)",
        "type": "string",
        "default": "postgres",
        "prompt": true,
        "required": true
      },
      {
        "name": "POSTGRES_USER",
        "description": "Default PostgreSQL User",
        "type": "string",
        "default": "postgres",
        "prompt": true,
        "required": true
      }
    ],
    "secrets": [
      {
        "name": "postgres_default_password",
        "description": "Create default PostgreSQL Password:",
        "type": "prompt_password",
        "addToCompose": true
      }
    ]
  },

  "traefik": {
    "supported": false
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "POSTGRESQL_PORT"
  },

  "status": {
    "file": "06_postgresql_status",
    "successMessage": "PostgreSQL Setup Completed",
    "telemetryAction": "postgresql"
  }
}
