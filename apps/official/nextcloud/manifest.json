{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "nextcloud",
    "pname": "Nextcloud",
    "description": "Nextcloud is a self-hosted productivity platform that provides file sync and share, collaboration tools, calendar, contacts, mail, and more. It offers a secure and private alternative to cloud services like Google Drive, Dropbox, and Microsoft 365.",
    "descriptionShort": "Open source content collaboration",
    "icon": "sh-nextcloud",
    "category": "official",
    "menuNumber": "06",
    "tags": ["files", "sync", "collaboration", "cloud", "storage", "office"]
  },

  "deployment": {
    "type": "multicontainer",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8081,
    "protocol": "http"
  },

  "dependencies": [
    {
      "sname": "nextcloud-mariadb",
      "pname": "Nextcloud MariaDB",
      "compose": "nextcloud-mariadb.yml",
      "installOrder": 1,
      "waitForHealthy": true,
      "required": true,
      "description": "Dedicated MariaDB database for Nextcloud"
    },
    {
      "sname": "nextcloud-redis",
      "pname": "Nextcloud Redis",
      "compose": "nextcloud-redis.yml",
      "installOrder": 2,
      "waitForHealthy": true,
      "required": true,
      "description": "Dedicated Redis cache for Nextcloud"
    }
  ],

  "requirements": {
    "prerequisites": ["prerequisites", "nextcloud_folder"],
    "apps": []
  },

  "preInstall": {
    "dialog": {
      "type": "warning",
      "title": "Nextcloud",
      "message": "\\n\\Z1NOTE:\\Zn Deployrr does not install the Nextcloud AIO (All-in-One) image. You may manually install Nextcloud AIO image but compatibility with Deployrr has not been tested.\\n\\nThis installation uses dedicated MariaDB and Redis containers for better isolation and easier management.\\n\\nDo you wish to proceed?",
      "cancelable": true
    }
  },

  "database": {
    "type": "mariadb",
    "containerSname": "nextcloud-mariadb",
    "name": "nextcloud",
    "user": "nextcloud_db_user",
    "passwordVariable": "NEXTCLOUD_MARIADB_PASSWORD",
    "host": "nextcloud-mariadb",
    "port": 3306
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "NEXTCLOUD_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "NEXTCLOUD_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8081,
        "prompt": true,
        "required": true,
        "validation": { "type": "port", "min": 1, "max": 65535 }
      },
      {
        "name": "NEXTCLOUD_SUBDOMAIN",
        "description": "Subdomain for Nextcloud (used for trusted domains)",
        "type": "string",
        "default": "nextcloud",
        "prompt": true,
        "required": true
      },
      {
        "name": "NEXTCLOUD_ADMIN_USER",
        "description": "Nextcloud admin username (pick something unique, not admin/root)",
        "type": "string",
        "default": "",
        "prompt": true,
        "required": true
      },
      {
        "name": "NEXTCLOUD_ADMIN_PASSWORD",
        "description": "Nextcloud admin password",
        "type": "password",
        "generate": "random",
        "length": 16,
        "prompt": true,
        "required": true
      },
      {
        "name": "NEXTCLOUD_MARIADB_ROOT_PASSWORD",
        "description": "MariaDB root password (auto-generated)",
        "type": "password",
        "generate": "random",
        "length": 32,
        "prompt": false,
        "required": true
      },
      {
        "name": "NEXTCLOUD_MARIADB_PASSWORD",
        "description": "MariaDB database password (auto-generated)",
        "type": "password",
        "generate": "random",
        "length": 32,
        "prompt": false,
        "required": true
      }
    ]
  },

  "postInstall": {
    "messages": [
      {
        "type": "info",
        "text": "Admin login: \\Z5$NEXTCLOUD_ADMIN_USER\\Zn / \\Z5$NEXTCLOUD_ADMIN_PASSWORD\\Zn"
      },
      {
        "type": "note",
        "text": "Nextcloud uses dedicated containers: \\Z5nextcloud-mariadb\\Zn and \\Z5nextcloud-redis\\Zn. Credentials are stored in \\Z4$DOCKER_FOLDER/.env\\Zn."
      },
      {
        "type": "note",
        "text": "Data folder: \\Z4$NEXTCLOUD_FOLDER\\Zn - Files uploaded to Nextcloud are stored here."
      },
      {
        "type": "note",
        "text": "For Traefik users: Edit \\Z4$DOCKER_FOLDER/compose/$HOSTNAME/nextcloud.yml\\Zn to uncomment NEXTCLOUD_TRUSTED_DOMAINS and OVERWRITEHOST after setup."
      }
    ]
  },

  "status": {
    "file": "06_nextcloud_status",
    "successMessage": "Nextcloud Setup Completed",
    "telemetryAction": "nextcloud"
  }
}
