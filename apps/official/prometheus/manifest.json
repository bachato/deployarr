{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "prometheus",
    "pname": "Prometheus",
    "description": "Prometheus is an open-source systems monitoring and alerting toolkit. It collects and stores metrics as time series data.",
    "descriptionShort": "Monitoring system and timeseries DB",
    "icon": "sh-prometheus",
    "category": "official",
    "menuNumber": "06",
    "tags": ["monitoring", "metrics", "timeseries", "alerting"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["dbs", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 9090,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "folders": {
    "appdata": ["config", "data"],
    "permissions": {
      "appdata": "$PUID:$PGID"
    }
  },

  "files": [
    {
      "source": "files/prometheus.yml",
      "dest": "$DOCKERDIR/appdata/prometheus/config/prometheus.yml"
    }
  ],

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "PROMETHEUS_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "PROMETHEUS_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 9090,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_prometheus_status",
    "successMessage": "Prometheus Setup Completed",
    "telemetryAction": "prometheus"
  }
}
