{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "airsonic-advanced",
    "pname": "Airsonic-Advanced",
    "description": "Airsonic-Advanced is a free, web-based media streamer for music. It provides instant streaming and downloading from any browser.",
    "descriptionShort": "Subsonic music server",
    "icon": "sh-airsonic",
    "category": "official",
    "menuNumber": "06",
    "tags": ["music", "media", "streaming", "subsonic"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["media", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 4040,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "media_folder", "appfolder_permission"],
    "apps": []
  },

  "postInstall": {
    "messages": [
      {
        "type": "note",
        "text": "$APP_PNAME default username/password are: admin/admin"
      }
    ]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "AIRSONICADVANCED_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "AIRSONICADVANCED_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 4040,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "folders": {
    "appdata": ["podcasts", "playlists", "config"]
  },

  "status": {
    "file": "06_airsonic-advanced_status",
    "successMessage": "Airsonic-Advanced Setup Completed",
    "telemetryAction": "airsonic-advanced"
  }
}
