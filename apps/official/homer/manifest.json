{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "homer",
    "pname": "Homer",
    "description": "Homer is a dead simple static HOMepage for your servER. It supports Docker integration for automatic service discovery.",
    "descriptionShort": "Homelab dashboard",
    "icon": "sh-homer",
    "category": "official",
    "menuNumber": "06",
    "tags": ["dashboard", "homepage", "launcher", "web"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default", "socket_proxy"],
    "webui": true,
    "port": 8081,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": ["socket-proxy"]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "HOMER_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "HOMER_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8081,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_homer_status",
    "successMessage": "Homer Setup Completed",
    "telemetryAction": "homer"
  }
}
