{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "portainer",
    "pname": "Portainer",
    "description": "Portainer is a lightweight management UI that allows you to easily manage your Docker host or Swarm cluster. It provides a comprehensive interface for container management.",
    "descriptionShort": "Container manager",
    "icon": "sh-portainer",
    "category": "official",
    "menuNumber": "06",
    "tags": ["docker", "management", "containers", "web"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["core", "all"],
    "networks": ["default", "socket_proxy"],
    "webui": true,
    "port": 9000,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": ["socket-proxy"]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "PORTAINER_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "PORTAINER_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 9000,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_portainer_status",
    "successMessage": "Portainer Setup Completed",
    "telemetryAction": "portainer"
  }
}
