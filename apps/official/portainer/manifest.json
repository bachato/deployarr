{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",
  "app": {
    "sname": "portainer",
    "pname": "Portainer",
    "description": "Portainer is a lightweight management UI that allows you to easily manage your Docker host or Swarm cluster. It provides a comprehensive interface for container management.",
    "descriptionShort": "Container manager",
    "icon": "sh-portainer",
    "category": "official",
    "menuNumber": "06",
    "tags": [
      "docker",
      "management",
      "containers",
      "web"
    ]
  },
  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": [
      "core",
      "all"
    ],
    "networks": [
      "default",
      "socket_proxy"
    ],
    "webui": true,
    "port": 9000,
    "protocol": "http"
  },
  "requirements": {
    "prerequisites": [
      "prerequisites"
    ],
    "apps": [
      "socket-proxy"
    ]
  },
  "traefik": {
    "supported": true
  },
  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "PORTAINER_PORT"
  },
  "hooks": {
    "preInstall": {
      "dialog": {
        "type": "info",
        "cancelable": false,
        "title": "Portainer Edition Selection",
        "message": "\\n\\Z1Portainer Edition Options\\Zn\\n\\nDeployrr can install either edition of Portainer:\\n\\n  \\Z2ce\\Zn = Community Edition (free, open-source)\\n  \\Z2ee\\Zn = Business Edition (paid, advanced features)\\n\\nBusiness Edition includes RBAC, GitOps support, edge computing, and priority support.\\n\\n\\Z1NOTE:\\Zn Business Edition requires a valid \\Z4license key\\Zn from:\\n\\Z4https://www.portainer.io/pricing\\Zn\\n\\nThe license key is entered in the Portainer web UI on first login.\\n\\nYou will be prompted to choose your edition next."
      }
    }
  },
  "env": {
    "variables": [
      {
        "name": "PORTAINER_EDITION",
        "description": "Edition: ce (Community/free) or ee (Business/licensed)",
        "type": "string",
        "default": "ce",
        "prompt": true,
        "required": true
      },
      {
        "name": "PORTAINER_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 9000,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },
  "status": {
    "file": "06_portainer_status",
    "successMessage": "Portainer Setup Completed",
    "telemetryAction": "portainer"
  }
}