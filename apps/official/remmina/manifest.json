{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",
  "app": {
    "sname": "remmina",
    "pname": "Remmina",
    "description": "Remmina is a remote desktop client that supports multiple protocols including RDP, VNC, SSH, and more. This container provides web-accessible Remmina with KasmVNC.",
    "descriptionShort": "Remote desktop client",
    "icon": "sh-remmina",
    "category": "official",
    "menuNumber": "06",
    "tags": [
      "remote",
      "desktop",
      "rdp",
      "vnc",
      "ssh"
    ]
  },
  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": [
      "core",
      "all"
    ],
    "networks": [
      "default"
    ],
    "webui": true,
    "port": 3003,
    "protocol": "http"
  },
  "requirements": {
    "prerequisites": [
      "prerequisites",
      "add_gpu"
    ],
    "apps": []
  },
  "gpu": {
    "required": false,
    "usage": "Hardware-accelerated rendering",
    "vendors": {
      "intel": {
        "pattern": "dri"
      },
      "amd": {
        "pattern": "dri"
      }
    }
  },
  "traefik": {
    "supported": true
  },
  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "REMMINA_PORT"
  },
  "env": {
    "variables": [
      {
        "name": "REMMINA_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 3003,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },
  "status": {
    "file": "06_remmina_status",
    "successMessage": "Remmina Setup Completed",
    "telemetryAction": "remmina"
  }
}