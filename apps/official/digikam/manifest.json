{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",
  "app": {
    "sname": "digikam",
    "pname": "DigiKam",
    "description": "DigiKam is an advanced open-source digital photo management application. It provides comprehensive tools for organizing, editing, and sharing photos.",
    "descriptionShort": "Open-source photo manager",
    "icon": "sh-digikam",
    "category": "official",
    "menuNumber": "06",
    "tags": [
      "photos",
      "images",
      "media",
      "management"
    ]
  },
  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": [
      "apps",
      "all"
    ],
    "networks": [
      "default"
    ],
    "webui": true,
    "port": 3005,
    "protocol": "http"
  },
  "requirements": {
    "prerequisites": [
      "prerequisites",
      "photos_folder",
      "add_gpu",
      "appfolder_permission"
    ],
    "apps": []
  },
  "gpu": {
    "required": false,
    "usage": "Hardware-accelerated rendering",
    "vendors": {
      "intel": {
        "pattern": "dri"
      },
      "amd": {
        "pattern": "dri"
      }
    }
  },
  "traefik": {
    "supported": true
  },
  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "DIGIKAM_PORT"
  },
  "env": {
    "variables": [
      {
        "name": "DIGIKAM_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 3005,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },
  "status": {
    "file": "06_digikam_status",
    "successMessage": "DigiKam Setup Completed",
    "telemetryAction": "digikam"
  }
}