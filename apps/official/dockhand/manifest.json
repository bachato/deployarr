{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "dockhand",
    "pname": "Dockhand",
    "description": "Dockhand is a self-hosted Docker container management tool that provides a web interface for monitoring and managing your Docker containers with PostgreSQL-backed persistence.",
    "descriptionShort": "Docker container management",
    "icon": "sh-dockhand",
    "category": "official",
    "menuNumber": "06",
    "tags": ["docker", "management", "containers", "monitoring"]
  },

  "deployment": {
    "type": "multicontainer",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default", "socket_proxy"],
    "webui": true,
    "port": 3000,
    "protocol": "http"
  },

  "dependencies": [
    {
      "sname": "dockhand-postgresql",
      "pname": "Dockhand PostgreSQL",
      "compose": "dockhand-postgresql.yml",
      "installOrder": 1,
      "waitForHealthy": true,
      "required": true,
      "description": "Dedicated PostgreSQL database for Dockhand"
    }
  ],

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": ["socket-proxy"]
  },

  "database": {
    "type": "postgresql",
    "containerSname": "dockhand-postgresql",
    "name": "dockhand",
    "user": "dockhand_db_user",
    "passwordVariable": "DOCKHAND_POSTGRESQL_PASSWORD",
    "host": "dockhand-postgresql",
    "port": 5432
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "DOCKHAND_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "DOCKHAND_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 3000,
        "prompt": true,
        "required": true,
        "validation": { "type": "port", "min": 1, "max": 65535 }
      },
      {
        "name": "DOCKHAND_POSTGRESQL_PASSWORD",
        "description": "PostgreSQL database password (auto-generated)",
        "type": "password",
        "generate": "random",
        "length": 32,
        "prompt": false,
        "required": true
      }
    ]
  },

  "postInstall": {
    "messages": [
      {
        "type": "note",
        "text": "Dockhand uses a dedicated PostgreSQL database (\\Z5dockhand-postgresql\\Zn). Database password is stored in \\Z4$DOCKER_FOLDER/.env\\Zn."
      },
      {
        "type": "warning",
        "text": "Dockhand does NOT have authentication enabled by default. Enable it manually from Dockhand's \\Z5Settings\\Zn menu."
      }
    ]
  },

  "status": {
    "file": "06_dockhand_status",
    "successMessage": "Dockhand Setup Completed",
    "telemetryAction": "dockhand"
  }
}
