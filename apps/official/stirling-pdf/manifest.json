{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "stirling-pdf",
    "pname": "Stirling PDF",
    "description": "Stirling PDF is a powerful, locally hosted web-based PDF manipulation tool that allows you to split, merge, convert, reorganize, add watermarks, and more to PDF files.",
    "descriptionShort": "Self-hosted PDF Manipulation",
    "icon": "sh-stirling-pdf",
    "category": "official",
    "menuNumber": "06",
    "tags": ["pdf", "tools", "documents"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8081,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "STIRLINGPDF_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "STIRLINGPDF_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8081,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_stirlingpdf_status",
    "successMessage": "Stirling PDF Setup Completed",
    "telemetryAction": "stirlingpdf"
  }
}
