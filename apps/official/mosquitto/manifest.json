{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "mosquitto",
    "pname": "Mosquitto",
    "description": "Eclipse Mosquitto is an open source message broker that implements the MQTT protocol, providing lightweight publish/subscribe messaging for IoT and home automation.",
    "descriptionShort": "MQTT broker",
    "icon": "sh-mosquitto",
    "category": "official",
    "menuNumber": "06",
    "tags": ["mqtt", "iot", "home-automation", "messaging"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": false,
    "port": 1883,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "folders": {
    "appdata": ["config", "data", "log"],
    "permissions": {
      "appdata": "1000:root"
    }
  },

  "files": [
    {
      "source": "files/mosquitto.conf",
      "dest": "$DOCKER_FOLDER/appdata/mosquitto/config/mosquitto.conf"
    },
    {
      "source": "files/passwd",
      "dest": "$DOCKER_FOLDER/appdata/mosquitto/config/passwd"
    }
  ],

  "hooks": {
    "postInstall": "files/post-install.sh"
  },

  "postInstall": {
    "messages": [
      {
        "type": "info",
        "text": "eclipse/mosquitto docker image may reset permissions upon recreation. You may ignore any permissions error at this point."
      }
    ]
  },

  "env": {
    "variables": [
      {
        "name": "MOSQUITTO_PORT",
        "description": "MQTT port",
        "type": "port",
        "default": 1883,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      },
      {
        "name": "MOSQUITTO_WS_PORT",
        "description": "MQTT WebSocket port",
        "type": "port",
        "default": 9001,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ],
    "secrets": [
      {
        "name": "mosquitto_username",
        "description": "Create default Mosquitto Username:",
        "type": "prompt",
        "addToCompose": false
      },
      {
        "name": "mosquitto_password",
        "description": "Create default Mosquitto Password:",
        "type": "prompt_password",
        "addToCompose": false
      }
    ]
  },

  "traefik": {
    "supported": false
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "MOSQUITTO_PORT"
  },

  "status": {
    "file": "06_mosquitto_status",
    "successMessage": "Mosquitto Setup Completed",
    "telemetryAction": "mosquitto"
  }
}
