{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "beets",
    "pname": "Beets",
    "description": "Beets is a music library manager and MusicBrainz-based tagger. It catalogs your collection, fixing metadata and organizing files.",
    "descriptionShort": "Music manager and MusicBrainz tagger",
    "icon": "sh-beets",
    "category": "official",
    "menuNumber": "06",
    "tags": ["music", "media", "tagger", "library"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["media", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8337,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "media_folder", "appfolder_permission"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "BEETS_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "BEETS_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8337,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_beets_status",
    "successMessage": "Beets Setup Completed",
    "telemetryAction": "beets"
  }
}
