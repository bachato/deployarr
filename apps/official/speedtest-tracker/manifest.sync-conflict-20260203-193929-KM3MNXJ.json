{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "speedtest-tracker",
    "pname": "Speedtest Tracker",
    "description": "Speedtest Tracker is a self-hosted internet performance tracking application that runs speed tests and displays the results in a beautiful UI. Track your internet speed over time with automatic scheduled tests.",
    "descriptionShort": "Internet speed tracker",
    "icon": "sh-speedtest-tracker",
    "category": "official",
    "menuNumber": "06",
    "tags": ["monitoring", "network", "speedtest", "internet"]
  },

  "deployment": {
    "type": "multicontainer",
    "compose": "compose.yml",
    "profiles": ["apps", "monitoring", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8081,
    "protocol": "http"
  },

  "dependencies": [
    {
      "sname": "speedtest-tracker-mariadb",
      "pname": "Speedtest Tracker MariaDB",
      "compose": "speedtest-tracker-mariadb.yml",
      "installOrder": 1,
      "waitForHealthy": true,
      "required": true,
      "description": "Dedicated MariaDB database for Speedtest Tracker"
    }
  ],

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "database": {
    "type": "mariadb",
    "containerSname": "speedtest-tracker-mariadb",
    "name": "speedtest",
    "user": "root",
    "passwordVariable": "SPEEDTEST_MARIADB_ROOT_PASSWORD",
    "host": "speedtest-tracker-mariadb",
    "port": 3306
  },

  "folders": {
    "permissions": {
      "appdata": "1000:1000"
    }
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "SPEEDTEST_TRACKER_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "SPEEDTEST_TRACKER_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8081,
        "prompt": true,
        "required": true,
        "validation": { "type": "port", "min": 1, "max": 65535 }
      },
      {
        "name": "SPEEDTEST_TRACKER_APP_KEY",
        "description": "App key for encrypting stored data (auto-generated)",
        "type": "string",
        "generate": "command",
        "command": "echo -n 'base64:'; openssl rand -base64 32",
        "prompt": false,
        "required": true
      },
      {
        "name": "SPEEDTEST_MARIADB_ROOT_PASSWORD",
        "description": "MariaDB root password (auto-generated)",
        "type": "password",
        "generate": "random",
        "length": 32,
        "prompt": false,
        "required": true
      }
    ]
  },

  "postInstall": {
    "messages": [
      {
        "type": "info",
        "text": "Default login: \\Z5admin@example.com\\Zn / \\Z5password\\Zn"
      },
      {
        "type": "note",
        "text": "Speedtest Tracker uses a dedicated MariaDB database (\\Z5speedtest-tracker-mariadb\\Zn). Database password is stored in \\Z4$DOCKER_FOLDER/.env\\Zn."
      }
    ]
  },

  "status": {
    "file": "06_speedtest-tracker_status",
    "successMessage": "Speedtest Tracker Setup Completed",
    "telemetryAction": "speedtest-tracker"
  }
}
