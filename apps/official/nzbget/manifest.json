{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "nzbget",
    "pname": "NZBGet",
    "description": "NZBGet is a binary downloader which downloads files from Usenet based on information given in nzb-files. It is written in C++ and known for its performance and efficiency.",
    "descriptionShort": "Usenet downloader",
    "icon": "sh-nzbget",
    "category": "official",
    "menuNumber": "06",
    "tags": ["downloads", "usenet"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "downloads", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 6789,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "downloads_folder", "appfolder_permission"],
    "apps": []
  },

  "postInstall": {
    "messages": [
      {
        "type": "note",
        "text": "NZBGet default username/password are: nzbget/tegbzn6789"
      }
    ]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "NZBGET_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "NZBGET_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 6789,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_nzbget_status",
    "successMessage": "NZBGet Setup Completed",
    "telemetryAction": "nzbget"
  }
}
