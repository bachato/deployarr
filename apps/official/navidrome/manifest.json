{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "navidrome",
    "pname": "Navidrome",
    "description": "Navidrome is an open source web-based music collection server and streamer. It is compatible with Subsonic/Airsonic APIs.",
    "descriptionShort": "Subsonic compatible music server",
    "icon": "sh-navidrome",
    "category": "official",
    "menuNumber": "06",
    "tags": ["music", "media", "streaming", "subsonic"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["media", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 4533,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "media_folder", "appfolder_permission"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "NAVIDROME_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "NAVIDROME_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 4533,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_navidrome_status",
    "successMessage": "Navidrome Setup Completed",
    "telemetryAction": "navidrome"
  }
}
