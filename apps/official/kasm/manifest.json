{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "kasm",
    "pname": "Kasm",
    "description": "Kasm Workspaces is a streaming platform for delivering browser-based access to desktops, applications, and web services. It uses Docker containers to provide isolated workspace environments.",
    "descriptionShort": "Remote workspaces",
    "icon": "sh-kasm-workspaces",
    "category": "official",
    "menuNumber": "06",
    "tags": ["remote", "desktop", "workspace", "browser"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 443,
    "protocol": "https"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "add_gpu", "appfolder_permission"],
    "systemType": ["Bare Metal", "VPS", "Virtual Machine", "Privileged LXC"],
    "apps": []
  },

  "postInstall": {
    "messages": [
      {
        "type": "note",
        "text": "First visit initial setup URL at: https://$SERVER_LAN_IP:$KASM_INSTALLATION_PORT"
      },
      {
        "type": "note",
        "text": "Kasm default username/password are: admin@kasm.local and user@kasm.local"
      }
    ]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "KASM_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "KASM_PORT",
        "description": "Web interface port (HTTPS)",
        "type": "port",
        "default": 443,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      },
      {
        "name": "KASM_INSTALLATION_PORT",
        "description": "Installation wizard port (HTTPS)",
        "type": "port",
        "default": 3000,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_kasm_status",
    "successMessage": "Kasm Setup Completed",
    "telemetryAction": "kasm"
  }
}
