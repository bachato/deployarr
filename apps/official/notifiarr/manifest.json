{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "notifiarr",
    "pname": "Notifiarr",
    "description": "Notifiarr is the client application for notifiarr.com, providing unified notifications for Starr apps and other services.",
    "descriptionShort": "Client for Notifiarr.com",
    "icon": "sh-notifiarr",
    "category": "official",
    "menuNumber": "06",
    "tags": ["notifications", "media", "monitoring"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["media", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 5454,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": { "supported": true },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "NOTIFIARR_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "NOTIFIARR_API_KEY",
        "description": "Enter your API Key from notifiarr.com",
        "type": "string",
        "prompt": true,
        "required": true
      },
      {
        "name": "NOTIFIARR_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 5454,
        "prompt": true,
        "required": true,
        "validation": { "type": "port", "min": 1, "max": 65535 }
      }
    ]
  },

  "postInstall": {
    "messages": [
      {
        "type": "note",
        "text": "Notifiarr default username/password are: admin / $NOTIFIARR_API_KEY"
      }
    ]
  },

  "status": {
    "file": "06_notifiarr_status",
    "successMessage": "Notifiarr Setup Completed",
    "telemetryAction": "notifiarr"
  }
}
