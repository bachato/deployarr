{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "double-commander",
    "pname": "Double Commander",
    "description": "Double Commander is a free cross platform open source file manager with two panels side by side. It is inspired by Total Commander and features some new ideas.",
    "descriptionShort": "Web-based File Manager",
    "icon": "sh-docker",
    "category": "official",
    "menuNumber": "06",
    "tags": ["files", "manager", "utility"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 3000,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "media_folder", "add_gpu"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "DOUBLECOMMANDER_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "DOUBLECOMMANDER_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 3000,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_double-commander_status",
    "successMessage": "Double Commander Setup Completed",
    "telemetryAction": "double-commander"
  }
}
