{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "cloudflare-tunnel",
    "pname": "Cloudflare Tunnel",
    "description": "Cloudflare Tunnel provides a secure way to connect your origin server to Cloudflare without a publicly routable IP address.",
    "descriptionShort": "Private network over internet",
    "icon": "sh-cloudflare",
    "category": "official",
    "menuNumber": "06",
    "tags": ["networking", "vpn", "security", "cloudflare"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["core", "all"],
    "networks": [],
    "webui": false,
    "port": 0,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "network_adapter"],
    "apps": []
  },

  "preInstall": {
    "dialog": {
      "type": "warning",
      "title": "Cloudflare Tunnel Token Required",
      "message": "\\n\\Z1NOTE!\\Zn\\n\\nYou will need to create a Tunnel on Cloudflare Zero Trust dashboard and have the tunnel token ready.\\n\\nDo you wish to proceed with installing Cloudflare Tunnel?",
      "cancelable": true
    }
  },

  "hooks": {
    "preInstall": "files/pre-install.sh"
  },

  "traefik": { "supported": false },

  "dashboard": {
    "enabled": false,
    "location": "local",
    "showStats": false,
    "portVariable": ""
  },

  "env": {
    "variables": [
      {
        "name": "CLOUDFLARE_TUNNEL_TOKEN",
        "description": "Cloudflare Tunnel Token",
        "type": "string",
        "prompt": true,
        "required": true
      }
    ]
  },

  "status": {
    "file": "06_cloudflare-tunnel_status",
    "successMessage": "Cloudflare Tunnel Setup Completed",
    "telemetryAction": "cloudflare-tunnel"
  }
}
