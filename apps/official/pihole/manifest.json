{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "pihole",
    "pname": "Pi-hole",
    "description": "Pi-hole is a network-level advertisement and internet tracker blocking application. It acts as a DNS sinkhole, protecting devices from unwanted content without installing any client-side software.",
    "descriptionShort": "DNS Server and AdBlocker",
    "icon": "sh-pi-hole",
    "category": "official",
    "menuNumber": "06",
    "tags": ["dns", "adblock", "networking", "security"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["all", "core"],
    "networks": ["default"],
    "webui": true,
    "port": 83,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "postInstall": {
    "messages": [
      {
        "type": "note",
        "text": "Use http://${SERVER_LAN_IP}:${PIHOLE_PORT}/admin/ or https://example.com/admin/ to access the Pi-hole WebUI."
      }
    ]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "PIHOLE_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "PIHOLE_WEB_PASSWORD",
        "description": "Pihole Web Password",
        "type": "password",
        "prompt": true,
        "required": true
      },
      {
        "name": "PIHOLE_LOCAL_DOMAIN",
        "description": "Pihole Local Domain (e.g. myhome.internal)",
        "type": "string",
        "default": "home.internal",
        "prompt": true,
        "required": true
      },
      {
        "name": "PIHOLE_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 83,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_pihole_status",
    "successMessage": "Pi-hole Setup Completed",
    "telemetryAction": "pihole"
  }
}
