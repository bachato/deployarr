{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",
  "app": {
    "sname": "lollypop",
    "pname": "Lollypop",
    "description": "Lollypop is a modern music player for GNOME. It provides features like streaming, YouTube support, and a beautiful interface for managing and playing your music collection.",
    "descriptionShort": "Music player",
    "icon": "sh-lollypop",
    "category": "official",
    "menuNumber": "06",
    "tags": [
      "media",
      "music",
      "player"
    ]
  },
  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": [
      "apps",
      "all"
    ],
    "networks": [
      "default"
    ],
    "webui": true,
    "port": 3001,
    "protocol": "http"
  },
  "requirements": {
    "prerequisites": [
      "prerequisites",
      "media_folder",
      "add_gpu"
    ],
    "apps": []
  },
  "gpu": {
    "required": false,
    "usage": "Hardware-accelerated rendering",
    "vendors": {
      "intel": {
        "pattern": "dri"
      },
      "amd": {
        "pattern": "dri"
      }
    }
  },
  "traefik": {
    "supported": true
  },
  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "LOLLYPOP_PORT"
  },
  "env": {
    "variables": [
      {
        "name": "LOLLYPOP_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 3001,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },
  "status": {
    "file": "06_lollypop_status",
    "successMessage": "Lollypop Setup Completed",
    "telemetryAction": "lollypop"
  }
}