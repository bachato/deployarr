{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "privatebin",
    "pname": "PrivateBin",
    "description": "PrivateBin is a minimalist, open source online pastebin where the server has zero knowledge of pasted data. Data is encrypted and decrypted in the browser using 256bit AES.",
    "descriptionShort": "Self-hosted Pastebin",
    "icon": "sh-privatebin",
    "category": "official",
    "menuNumber": "06",
    "tags": ["pastebin", "privacy", "encryption", "sharing"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8081,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "traefik_production"],
    "apps": []
  },

  "folders": {
    "appdata": ["data"],
    "custom": [
      {
        "path": "$DOCKERDIR/appdata/privatebin/data",
        "permissions": "777"
      }
    ]
  },

  "files": [
    {
      "source": "files/conf.php",
      "dest": "$DOCKERDIR/appdata/privatebin/conf.php"
    }
  ],

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "PRIVATEBIN_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "PRIVATEBIN_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8081,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_privatebin_status",
    "successMessage": "PrivateBin Setup Completed",
    "telemetryAction": "privatebin"
  }
}
