{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",
  "app": {
    "sname": "emby",
    "pname": "Emby",
    "description": "Emby is a media server designed to organize, play, and stream audio and video to a variety of devices. It offers live TV, DVR, and hardware transcoding.",
    "descriptionShort": "Media server",
    "icon": "sh-emby",
    "category": "official",
    "menuNumber": "06",
    "tags": [
      "media",
      "streaming",
      "video",
      "music",
      "tv"
    ]
  },
  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": [
      "media",
      "all"
    ],
    "networks": [
      "default"
    ],
    "webui": true,
    "port": 8096,
    "protocol": "http"
  },
  "requirements": {
    "prerequisites": [
      "prerequisites",
      "media_folder",
      "downloads_folder",
      "add_gpu",
      "appfolder_permission"
    ],
    "apps": []
  },
  "gpu": {
    "required": false,
    "usage": "Hardware transcoding",
    "vendors": {
      "intel": {
        "pattern": "dri"
      },
      "amd": {
        "pattern": "dri"
      },
      "nvidia": {
        "pattern": "runtime"
      }
    }
  },
  "traefik": {
    "supported": true
  },
  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "EMBY_PORT"
  },
  "env": {
    "variables": [
      {
        "name": "EMBY_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8096,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      },
      {
        "name": "EMBY_SERVER_NAME",
        "description": "What you want to name this Emby server?",
        "type": "string",
        "default": "Emby Server",
        "prompt": true,
        "required": true
      }
    ]
  },
  "status": {
    "file": "06_emby_status",
    "successMessage": "Emby Setup Completed",
    "telemetryAction": "emby"
  }
}