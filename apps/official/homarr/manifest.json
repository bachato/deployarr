{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "homarr",
    "pname": "Homarr",
    "description": "Homarr is a sleek, modern dashboard that puts all of your apps and services at your fingertips. With Homarr you can access and control everything in one convenient location.",
    "descriptionShort": "Homelab dashboard",
    "icon": "sh-homarr",
    "category": "official",
    "menuNumber": "06",
    "tags": ["dashboard", "homepage", "widgets", "integrations"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default", "socket_proxy"],
    "webui": true,
    "port": 7575,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": ["socket-proxy"]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "HOMARR_PORT"
  },

  "folders": {
    "appdata": [
      "homarr/configs",
      "homarr/icons",
      "homarr/data"
    ]
  },

  "env": {
    "variables": [
      {
        "name": "HOMARR_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 7575,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_homarr_status",
    "successMessage": "Homarr Setup Completed",
    "telemetryAction": "homarr"
  }
}
