{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "homepage",
    "pname": "Homepage",
    "description": "Homepage is a modern, fully static, fast, and secure application dashboard with over 100 integrations and widgets. It supports Docker integration for automatic service discovery.",
    "descriptionShort": "Homelab dashboard",
    "icon": "sh-homepage",
    "category": "official",
    "menuNumber": "06",
    "tags": ["dashboard", "homepage", "widgets", "integrations"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default", "socket_proxy"],
    "webui": true,
    "port": 3001,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": ["socket-proxy"]
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "HOMEPAGE_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "HOMEPAGE_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 3001,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_homepage_status",
    "successMessage": "Homepage Setup Completed",
    "telemetryAction": "homepage"
  }
}
