{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "baikal",
    "pname": "Baikal",
    "description": "Baikal is a lightweight CalDAV and CardDAV server for managing users, address books, and calendars. It supports multiple users and offers a simple web interface for configuration.",
    "descriptionShort": "Users, address books, calendars",
    "icon": "sh-baikal",
    "category": "official",
    "menuNumber": "06",
    "tags": ["calendar", "contacts", "carddav", "caldav"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8081,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "BAIKAL_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "BAIKAL_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8081,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_baikal_status",
    "successMessage": "Baikal Setup Completed",
    "telemetryAction": "baikal"
  }
}
