{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "homebridge",
    "pname": "Homebridge",
    "description": "Homebridge allows you to integrate with smart home devices that do not natively support HomeKit. It acts as a bridge between HomeKit and third-party home automation systems.",
    "descriptionShort": "Integration for HomeKit devices",
    "icon": "sh-homebridge",
    "category": "official",
    "menuNumber": "06",
    "tags": ["automation", "homekit", "smart-home"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": [],
    "networkMode": "host",
    "webui": true,
    "port": 8581,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "HOMEBRIDGE_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "HOMEBRIDGE_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8581,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_homebridge_status",
    "successMessage": "Homebridge Setup Completed",
    "telemetryAction": "homebridge"
  }
}
