{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "viniplay",
    "pname": "Viniplay",
    "description": "Viniplay is a self-hosted IPTV player for streaming live TV channels.",
    "descriptionShort": "Self-hosted IPTV Player",
    "icon": "mdi-play-box",
    "category": "official",
    "menuNumber": "06",
    "tags": ["media", "iptv", "streaming"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8998,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "hooks": {
    "preInstall": "files/pre-install.sh"
  },

  "traefik": { "supported": true },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "VINIPLAY_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "VINIPLAY_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8998,
        "prompt": true,
        "required": true,
        "validation": { "type": "port", "min": 1, "max": 65535 }
      }
    ]
  },

  "status": {
    "file": "06_viniplay_status",
    "successMessage": "Viniplay Setup Completed",
    "telemetryAction": "viniplay"
  }
}
