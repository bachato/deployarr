{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "wallos",
    "pname": "Wallos",
    "description": "Wallos is an open-source, self-hosted web application designed to help you manage your subscriptions and track recurring expenses. It features a clean UI and notification support.",
    "descriptionShort": "Open-source Subscription Tracker",
    "icon": "sh-wallos",
    "category": "official",
    "menuNumber": "06",
    "tags": ["finance", "subscriptions", "tracking"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 82,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "WALLOS_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "WALLOS_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 82,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_wallos_status",
    "successMessage": "Wallos Setup Completed",
    "telemetryAction": "wallos"
  }
}
