{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "boxarr",
    "pname": "Boxarr",
    "description": "Boxarr monitors weekly box office charts and seamlessly integrates with Radarr to ensure your media library always has what people want to watch. No more manual searching for popular movies - Boxarr handles it automatically.",
    "descriptionShort": "Box office to Radarr automation",
    "icon": "sh-boxarr",
    "category": "official",
    "menuNumber": "06",
    "tags": ["media", "automation", "arr"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["apps", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8888,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "BOXARR_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "BOXARR_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8888,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_boxarr_status",
    "successMessage": "Boxarr Setup Completed",
    "telemetryAction": "boxarr"
  }
}
