{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "xpipe-webtop",
    "pname": "XPipe Webtop",
    "description": "XPipe Webtop is a web-based desktop environment that provides a full Linux desktop accessible through your browser with XPipe connection management built-in.",
    "descriptionShort": "Web desktop environment",
    "icon": "sh-xpipe",
    "category": "official",
    "menuNumber": "06",
    "tags": ["desktop", "web", "remote", "xpipe"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["core", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 3004,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites", "add_gpu"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "XPIPEWEBTOP_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "XPIPEWEBTOP_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 3004,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_xpipe-webtop_status",
    "successMessage": "XPipe Webtop Setup Completed",
    "telemetryAction": "xpipe-webtop"
  }
}
