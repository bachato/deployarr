{
  "$schema": "../../../apps/manifest-schema.json",
  "version": "1.2",

  "app": {
    "sname": "vscode",
    "pname": "VS Code",
    "description": "VS Code Server is a Visual Studio Code-based IDE that runs in a browser. It provides a full-featured code editor with extensions, IntelliSense, and debugging capabilities.",
    "descriptionShort": "Visual Studio code server",
    "icon": "sh-visual-studio-code",
    "category": "official",
    "menuNumber": "06",
    "tags": ["development", "editor", "ide"]
  },

  "deployment": {
    "type": "single",
    "compose": "compose.yml",
    "profiles": ["core", "all"],
    "networks": ["default"],
    "webui": true,
    "port": 8443,
    "protocol": "http"
  },

  "requirements": {
    "prerequisites": ["prerequisites"],
    "apps": []
  },

  "traefik": {
    "supported": true
  },

  "dashboard": {
    "enabled": true,
    "location": "local",
    "showStats": true,
    "portVariable": "VSCODE_PORT"
  },

  "env": {
    "variables": [
      {
        "name": "VSCODE_PORT",
        "description": "Web interface port",
        "type": "port",
        "default": 8443,
        "prompt": true,
        "required": true,
        "validation": {
          "type": "port",
          "min": 1,
          "max": 65535
        }
      }
    ]
  },

  "status": {
    "file": "06_vscode_status",
    "successMessage": "VS Code Setup Completed",
    "telemetryAction": "vscode"
  }
}
