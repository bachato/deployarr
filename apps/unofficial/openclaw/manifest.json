{
    "$schema": "../../../apps/manifest-schema.json",
    "version": "1.2",
    "app": {
        "sname": "openclaw",
        "pname": "OpenClaw",
        "description": "OpenClaw is an open-source AI coding assistant and gateway that routes to Claude, GPT, Gemini, and other LLMs. It provides a self-hosted web interface for AI-assisted development with agent sandboxing and multi-provider support.",
        "descriptionShort": "AI assistant (9Router recommended)",
        "icon": "https://raw.githubusercontent.com/openclaw/openclaw/main/ui/public/favicon.svg",
        "category": "unofficial",
        "menuNumber": "06",
        "tags": [
            "ai",
            "development",
            "coding",
            "llm",
            "pro"
        ]
    },
    "deployment": {
        "type": "single",
        "compose": "compose.yml",
        "profiles": [
            "apps",
            "all"
        ],
        "networks": [
            "default"
        ],
        "build": {
            "imageName": "deployrr/openclaw:latest",
            "localBuild": true,
            "repoUrl": "https://github.com/openclaw/openclaw.git"
        },
        "webui": true,
        "port": 18789,
        "protocol": "http"
    },
    "requirements": {
        "prerequisites": [
            "prerequisites",
            "pro"
        ]
    },
    "env": {
        "variables": [
            {
                "name": "OPENCLAW_PORT",
                "description": "OpenClaw gateway web interface port",
                "type": "port",
                "default": 18789,
                "prompt": true,
                "required": true,
                "validation": {
                    "type": "port",
                    "min": 1,
                    "max": 65535
                }
            }
        ],
        "secrets": [
            {
                "name": "openclaw_gateway_token",
                "description": "Gateway authentication token for OpenClaw. This secures access to the web UI.",
                "type": "random",
                "length": 32,
                "addToCompose": false
            },
            {
                "name": "openclaw.env",
                "description": "Derived env file containing OPENCLAW_GATEWAY_TOKEN for env_file injection. Written by pre-install.sh — not generated by Deployrr. Tracked here for uninstall cleanup only.",
                "type": "derived",
                "addToCompose": false
            }
        ],
        "constants": [
            {
                "name": "OPENCLAW_CONFIG_DIR",
                "value": "$DOCKERDIR/appdata/openclaw/config",
                "description": "OpenClaw configuration directory"
            },
            {
                "name": "OPENCLAW_WORKSPACE_DIR",
                "value": "$DOCKERDIR/appdata/openclaw/workspace",
                "description": "OpenClaw workspace directory"
            }
        ]
    },
    "hooks": {
        "preInstall": {
            "dialog": {
                "type": "warning",
                "title": "OpenClaw - Build from Source",
                "message": "\\Z1IMPORTANT:\\Zn OpenClaw is an \\Z4unofficial\\Zn app that must be built from source.\\n\\nThe first install will:\\n• Clone the OpenClaw repository from GitHub\\n• Build the Docker image locally (may take 5-10 minutes)\\n• Require an active internet connection\\n\\nSubsequent starts will use the cached image.\\n\\nDo you want to proceed?"
            },
            "script": "files/pre-install.sh"
        },
        "postInstall": {
            "script": "files/post-install.sh",
            "messages": [
                {
                    "style": "info",
                    "text": "OpenClaw gateway is running at http://$SERVER_LAN_IP:$OPENCLAW_PORT"
                },
                {
                    "style": "note",
                    "text": "Your gateway token has been saved to $DOCKER_FOLDER/secrets/openclaw_gateway_token"
                },
                {
                    "style": "warning",
                    "text": "REQUIRED: Open the web UI → Settings → Token → paste the gateway token to connect! Without this step you will see 'gateway token missing' error."
                },
                {
                    "style": "info",
                    "text": "If 9Router is installed: Open 9Router dashboard → Providers → connect at least one provider → OpenClaw is ready!"
                },
                {
                    "style": "note",
                    "text": "If 9Router is NOT installed: Configure API providers manually via OpenClaw Settings or use: docker exec -it openclaw openclaw configure"
                },
                {
                    "style": "info",
                    "text": "For more info: https://docs.openclaw.ai/install/docker"
                }
            ],
            "copyValue": "$OPENCLAW_GATEWAY_TOKEN",
            "copyLabel": "Copy Token"
        }
    },
    "folders": {
        "appdata": [
            "config",
            "workspace"
        ]
    },
    "traefik": {
        "supported": true
    },
    "dashboard": {
        "enabled": true,
        "location": "local",
        "showStats": true,
        "portVariable": "OPENCLAW_PORT"
    },
    "status": {
        "file": "06_openclaw_status",
        "successMessage": "OpenClaw Setup Completed",
        "telemetryAction": "openclaw"
    }
}